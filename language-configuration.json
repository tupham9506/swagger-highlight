{
    "comments": {
        "lineComment": "//",
        "blockComment": [ "/*", "*/" ]
    },
    "indentationRules": {
        "increaseIndentPattern": "^\\s*\\*?\\s*@OA\\\\[a-zA-Z]+\\(",
        "decreaseIndentPattern": "^\\s*\\*?\\s*\\)"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*\\*?\\s*@OA\\\\[a-zA-Z]+\\(.*",
            "afterText": "^\\s*\\*?\\s*\\)",
            "action": {
                "indent": "indentOutdent",
                "appendText": " *     "
            }
        },
        {
            "beforeText": "^\\s*\\*?\\s*@OA\\\\[a-zA-Z]+\\(.*",
            "action": {
                "indent": "indent",
                "appendText": " *     "
            }
        }
    ],
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ]
}